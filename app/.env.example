# Local environment variables for Verified Dating App
# Copy to `.env.local` and fill with your Supabase project credentials.

APP_NAME=Connect
APP_THEME_MODE=light
# API environment switch
# API_ENV=local|production (or prod)
API_ENV=local
API_LOCAL_BASE_URL=http://10.0.2.2:8080/v1
API_PROD_BASE_URL=http://72.61.242.87/v1
# Optional override; if set, this wins over API_ENV and the two URLs above.
# API_BASE_URL=http://10.0.2.2:8080/v1
API_TIMEOUT_MS=30000
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Mock/runtime fallbacks
MOCK_USER_PREFIX=mock-user
MOCK_USER_ID=mock-user-001
MOCK_OTP_CODE=123456
MOCK_MATCHED_PROFILE_IDS=mock-female-001,mock-male-001
MOCK_FEMALE_USERS_COUNT=100
MOCK_MALE_USERS_COUNT=100
MOCK_MIN_AGE_YEARS=18
MOCK_MAX_AGE_YEARS=45
PLACEHOLDER_PROFILE_IMAGE_URL=https://images.unsplash.com/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&w=900&q=80
PLACEHOLDER_AVATAR_IMAGE_URL=https://images.unsplash.com/photo-1521572267360-ee0c2909d518?auto=format&fit=crop&w=500&q=80

# Optional Supabase table override (schema.table)
SUPABASE_USERS_TABLE=user_management.users
