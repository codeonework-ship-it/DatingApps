# Shared
ENVIRONMENT=development
LOG_LEVEL=debug
API_PREFIX=/v1

# HTTP / gRPC addresses
API_GATEWAY_ADDR=:8080
MOBILE_BFF_ADDR=:8081
MOBILE_BFF_UPSTREAM_URL=http://localhost:8081
AUTH_SVC_GRPC_ADDR=:9091
PROFILE_SVC_GRPC_ADDR=:9092
MATCHING_SVC_GRPC_ADDR=:9093
CHAT_SVC_GRPC_ADDR=:9094
AUTH_SVC_ADMIN_ADDR=:10091
PROFILE_SVC_ADMIN_ADDR=:10092
MATCHING_SVC_ADMIN_ADDR=:10093
CHAT_SVC_ADMIN_ADDR=:10094

# Timeouts / rate limits
API_GATEWAY_READ_HEADER_TIMEOUT_SEC=10
MOBILE_BFF_READ_HEADER_TIMEOUT_SEC=10
SHUTDOWN_TIMEOUT_SEC=10
BFF_REQUEST_TIMEOUT_SEC=8
GATEWAY_READY_TIMEOUT_SEC=2
GATEWAY_RATE_LIMIT_REQUESTS=120
GATEWAY_RATE_LIMIT_WINDOW_SEC=1
GATEWAY_MAX_INFLIGHT=2000
GATEWAY_RETRY_AFTER_SEC=1
GATEWAY_SKIP_POSTGRES_PROBE=false
BFF_MAX_INFLIGHT=1500
BFF_RETRY_AFTER_SEC=1
BFF_BULKHEAD_AUTH_MAX_INFLIGHT=200
BFF_BULKHEAD_PROFILE_MAX_INFLIGHT=300
BFF_BULKHEAD_MATCHING_MAX_INFLIGHT=400
BFF_BULKHEAD_MESSAGING_MAX_INFLIGHT=300
BFF_BULKHEAD_ENGAGEMENT_MAX_INFLIGHT=300
BFF_BULKHEAD_ADMIN_MAX_INFLIGHT=80
IDEMPOTENCY_TTL_SECONDS=600
AUTH_HTTP_TIMEOUT_SEC=12
SUPABASE_HTTP_TIMEOUT_SEC=15

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_READ_REPLICA_URL=
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE=your_service_role_key

# Supabase Postgres connection pieces (optional but recommended)
# If SUPABASE_URL is omitted and SUPABASE_DB_HOST matches db.<project-ref>.supabase.co,
# runtime derives SUPABASE_URL as https://<project-ref>.supabase.co.
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_db_password
SUPABASE_DB_SSLMODE=require
# Optional explicit DSN override (otherwise built from SUPABASE_DB_* values)
SUPABASE_DATABASE_URL=
DATABASE_URL=

# Supabase schema/table mapping
SUPABASE_USER_SCHEMA=public
SUPABASE_USERS_TABLE=users
SUPABASE_PREFERENCES_TABLE=preferences
SUPABASE_PHOTOS_TABLE=photos
SUPABASE_MATCHING_SCHEMA=public
SUPABASE_SWIPES_TABLE=swipes
SUPABASE_MATCHES_TABLE=matches
SUPABASE_MESSAGES_TABLE=messages
SUPABASE_ENGAGEMENT_SCHEMA=public
SUPABASE_UNLOCK_STATES_TABLE=match_unlock_states
SUPABASE_QUEST_TEMPLATES_TABLE=match_quest_templates
SUPABASE_QUEST_WORKFLOWS_TABLE=match_quest_workflows

# Chat realtime and workers
CHAT_WORKER_COUNT=8
CHAT_WORKER_QUEUE_SIZE=256
CHAT_REALTIME_SCHEMA=public
CHAT_REALTIME_TABLE=messages
CHAT_REALTIME_MAX_EVENTS=512
CHAT_REALTIME_LOG_LEVEL=warn
CHAT_REALTIME_HEARTBEAT_SEC=25
FANOUT_WORKER_COUNT=8
FANOUT_QUEUE_SIZE=4096
MASTER_DATA_CACHE_TTL_SECONDS=300

# Fallback media URLs
DEFAULT_PROFILE_IMAGE_URL=https://images.unsplash.com/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&w=900&q=80
DEFAULT_AVATAR_IMAGE_URL=https://images.unsplash.com/photo-1521572267360-ee0c2909d518?auto=format&fit=crop&w=500&q=80
MOCK_PHOTO_SEED_URL_TEMPLATE=https://picsum.photos/seed/%s/720/960
MOCK_BLOCKED_PHOTO_URL_TEMPLATE=https://picsum.photos/seed/%s/200/200
MEDIA_UPLOADS_DIR=.run/uploads/profile_photos
MEDIA_PUBLIC_BASE_URL=auto

# File storage backend
# local_fs keeps uploads on the backend host filesystem.
# Set FILE_STORAGE_BACKEND=aws_s3 and USE_AWS_S3_STORAGE=true when S3-backed
# uploads are implemented/enabled for your environment.
FILE_STORAGE_BACKEND=local_fs
USE_AWS_S3_STORAGE=false
AWS_S3_REGION=
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_PROFILE_PHOTOS_PREFIX=profile-photos
AWS_S3_FORCE_PATH_STYLE=false

# Optional for testing OTP without external SMS provider
MOCK_OTP_ENABLED=true
MOCK_OTP_CODE=123456
MOCK_USER_ID=mock-user-001
MOCK_ACCESS_TOKEN=mock-access-token
MOCK_REFRESH_TOKEN=mock-refresh-token
MOCK_FEMALE_USERS_COUNT=100
MOCK_MALE_USERS_COUNT=100
MOCK_MIN_AGE_YEARS=18
MOCK_MAX_AGE_YEARS=45
